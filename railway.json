{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "src/**",
      "server/**",
      "prisma/**"
    ]
  },
  "deploy": {
    "startCommand": "npx prisma db push --accept-data-loss && npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  }
}
